# ── ClubExpress ────────────────────────────────────────────
# Base URL for your club's ClubExpress site
CE_BASE_URL=https://yourclub.clubexpress.com

# Login credentials (if rides page requires auth)
CE_USERNAME=
CE_PASSWORD=

# How many days back to scrape (default: 7)
CE_LOOKBACK_DAYS=7

# ── RideWithGPS ────────────────────────────────────────────
RWGPS_API_KEY=
# Optional: your RWGPS user ID to scope route searches to your club
RWGPS_USER_ID=

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:////data/rides.db

# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production

# ── Scheduler ──────────────────────────────────────────────
# Cron expression for automatic scraping (default: Monday 6 AM)
SCRAPE_SCHEDULE=0 6 * * 1
